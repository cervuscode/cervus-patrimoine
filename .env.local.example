# Twilio Verify — OTP SMS
# Dashboard : console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_VERIFY_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Brevo — Email transactionnel + CRM contacts
# Paramètres Brevo → API & Intégrations → Clés API
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Make.com — Webhook Simulateur PER (à remplir après création du scénario Make)
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Make.com — Webhook Simulateur Assurance-vie (scénario Make DÉDIÉ, isolé du PER)
MAKE_WEBHOOK_URL_AV=https://hook.eu1.make.com/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pipedrive — Sync CRM Person + Deal (appel API direct côté serveur, jamais exposé au client)
# Token : Paramètres Pipedrive → Préférences personnelles → API
# Domaine : sous-domaine du compte (ex. "cervus" pour cervus.pipedrive.com),
#           ou domaine complet "cervus.pipedrive.com"
PIPEDRIVE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PIPEDRIVE_DOMAIN=cervus

# ─────────────────────────────────────────────────────────────────────────────
# Outil RDV Conseiller (app.cervuspatrimoine.fr) — Lot 0 : auth Google OAuth
# ─────────────────────────────────────────────────────────────────────────────
# Identifiants OAuth 2.0 créés dans Google Cloud Console (écran de consentement
# interne Workspace + Client ID type "Web application").
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# Secret de signature des sessions NextAuth (JWT). Générer avec :
#   openssl rand -base64 32
NEXTAUTH_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx=

# URL canonique de l'espace conseiller.
#   Production : https://app.cervuspatrimoine.fr
#   Dev local  : http://app.localhost:3000
NEXTAUTH_URL=https://app.cervuspatrimoine.fr

# Domaine Workspace autorisé (vérifié server-side dans le callback signIn).
ALLOWED_DOMAIN=cervuspatrimoine.fr
