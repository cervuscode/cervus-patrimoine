# Twilio Verify — OTP SMS
# Dashboard : console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_VERIFY_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Brevo — Email transactionnel + CRM contacts
# Paramètres Brevo → API & Intégrations → Clés API
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Make.com — Webhook Simulateur PER (à remplir après création du scénario Make)
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pipedrive — Sync CRM Person + Deal (appel API direct côté serveur, jamais exposé au client)
# Token : Paramètres Pipedrive → Préférences personnelles → API
# Domaine : sous-domaine du compte (ex. "cervus" pour cervus.pipedrive.com),
#           ou domaine complet "cervus.pipedrive.com"
PIPEDRIVE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PIPEDRIVE_DOMAIN=cervus
